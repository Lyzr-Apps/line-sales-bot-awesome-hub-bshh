{
  "agent_id": "699a8f14e6195f9129d6b924",
  "agent_name": "LINE Sales Bot Agent",
  "agent_type": "json",
  "has_module_outputs": false,
  "accessor": "result.response.result.{field_name}",
  "response_schema": {
    "type": "json_schema",
    "json_schema": {
      "name": "LineSalesBotResponse",
      "strict": true,
      "schema": {
        "type": "object",
        "properties": {
          "response_text": {
            "type": "string",
            "description": "The chatbot reply message to send to the customer"
          },
          "intent": {
            "type": "string",
            "description": "Detected customer intent: inquiry, recommendation, purchase, faq, complaint, greeting, other"
          },
          "products_mentioned": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "price": { "type": "string" },
                "availability": { "type": "string" }
              },
              "required": ["name", "price", "availability"],
              "additionalProperties": false
            },
            "description": "Products referenced in the response"
          },
          "order_collected": {
            "type": "boolean",
            "description": "Whether an order was successfully collected in this interaction"
          },
          "order_summary": {
            "type": "string",
            "description": "Summary of the order if one was collected, empty string otherwise"
          }
        },
        "required": ["response_text", "intent", "products_mentioned", "order_collected", "order_summary"],
        "additionalProperties": false
      }
    }
  }
}
